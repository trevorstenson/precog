{
  "name": "navbandit",
  "version": "0.2.0",
  "description": "Contextual bandit prefetching — learns which pages to prefetch per-user in real-time via LinUCB + Speculation Rules API",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trevorstenson/navbandit.git"
  },
  "homepage": "https://github.com/trevorstenson/navbandit#readme",
  "bugs": {
    "url": "https://github.com/trevorstenson/navbandit/issues"
  },
  "exports": {
    "./sw": {
      "types": "./dist/sw.d.ts",
      "import": "./dist/sw.js",
      "require": "./dist/sw.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./fallback": {
      "types": "./dist/fallback.d.ts",
      "import": "./dist/fallback.js",
      "require": "./dist/fallback.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "prefetch",
    "speculation-rules",
    "bandit",
    "linucb",
    "performance",
    "service-worker"
  ],
  "author": "Trevor Stenson",
  "license": "MIT",
  "devDependencies": {
    "fake-indexeddb": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
